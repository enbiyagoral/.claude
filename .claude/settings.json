{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)"
    ],
    "deny": [
      "Bash(git push *force*)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *production*)",
      "Bash(rm -rf *)",
      "Bash(docker system prune *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Post-compaction reminder: check CLAUDE.md for project conventions. Preserve the list of modified files and test commands from before compaction.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scripts/post-edit-lint.sh"
          },
          {
            "type": "command",
            "command": "echo '✓ File changed — lint auto-ran via post-edit hook'"
          }
        ]
      }
    ]
  }
}