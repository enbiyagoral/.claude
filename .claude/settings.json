{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)"
    ],
    "deny": [
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *production*)",
      "Bash(rm -rf *)",
      "Bash(docker system prune *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '✓ Dosya değişikliği yapıldı — lint ve typecheck çalıştırmayı unutma'"
          }
        ]
      }
    ]
  }
}