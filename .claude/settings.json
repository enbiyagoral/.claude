{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)"
    ],
    "deny": [
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *production*)",
      "Bash(rm -rf *)",
      "Bash(docker system prune *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/scripts/post-edit-lint.sh"
          },
          {
            "type": "command",
            "command": "echo '✓ File changed — lint auto-ran via post-edit hook'"
          }
        ]
      }
    ]
  }
}